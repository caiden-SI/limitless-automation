# Limitless Media Agency — Environment Variables
# All values sourced from 1Password vault: "Limitless - Caiden"

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# ClickUp
CLICKUP_API_KEY=
CLICKUP_WEBHOOK_SECRET=
CLICKUP_AUSTIN_LIST_ID=901707767654
CLICKUP_FRAMEIO_FIELD_ID=53590f25-d850-4c19-8c7a-7b005904e04a
CLICKUP_DROPBOX_FIELD_ID=d818eb86-41ce-416f-98aa-b1d92f13459f
# DEPRECATED 2026-05-12 — the "Internal Video Name" custom field was removed
# from the Austin ClickUp list. Scripting now writes the concept title to the
# task's `name` field directly. agents/scripting.js no longer reads this var.
# Kept here so older .env files don't surface as missing during diff review.
CLICKUP_INTERNAL_VIDEO_NAME_FIELD_ID=
CLICKUP_PROJECT_DESCRIPTION_FIELD_ID=8799f3b7-3385-4f9f-9a1b-b8872ecc78f4
# Optional. If set, pipeline.recordPostUrl prefers this field over description
# scanning when status flips to "posted by client". Falls back to scanning the
# task body for any TikTok/Instagram/YouTube/X URL when unset or empty.
CLICKUP_POST_URL_FIELD_ID=

# Dropbox
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_ACCESS_TOKEN=

# Frame.io v4 (migrated from v2 on 2026-05-08)
# OAuth Server-to-Server credentials from console.adobe.io for the Frame.io v4 product
FRAMEIO_OAUTH_CLIENT_ID=
FRAMEIO_OAUTH_CLIENT_SECRET=
# Space-separated scopes shown by Adobe Developer Console for the credential
FRAMEIO_OAUTH_SCOPES=
# Optional: override IMS endpoint if Adobe routed your account outside NA
# FRAMEIO_OAUTH_IMS_ENDPOINT=https://ims-na1.adobelogin.com

# Frame.io v4 account + workspace IDs (from next.frame.io URL or GET /v4/accounts/{id}/workspaces)
FRAMEIO_ACCOUNT_ID=
FRAMEIO_WORKSPACE_ID=

# Webhook signing secret returned ONLY at webhook creation time
# Run scripts/register-frameio-webhook.js to create a webhook and obtain this value
FRAMEIO_WEBHOOK_SECRET=

# Legacy v2 token — no longer used after v4 migration. Safe to remove.
# FRAMEIO_API_TOKEN=

# Fireflies
FIREFLIES_API_KEY=
# Cron gate for the Fireflies Agent (agents/fireflies.js). Leave unset (or
# anything other than "true") to keep the 9PM nightly cron OFF. Flip to
# "true" only on cutover night, AFTER Scott confirms his fireflies_sync.py
# cron is disabled — running both produces duplicate ClickUp tasks.
# Procedure: workflows/fireflies-integration.md §"Cutover".
FIREFLIES_CRON_ENABLED=
# Optional: if set, scripts/test-fireflies-integration.js posts test action
# items to this list instead of the production Austin list (901707767654).
# When unset, the test skips ClickUp-write assertions and only exercises
# Fireflies + Supabase + dedup paths.
CLICKUP_TEST_LIST_ID=

# Google Calendar
# The same service-account JSON is reused by lib/google.js (Sheets) for the
# performance tracker sync. Grant the service account email Viewer access on
# the Content Performance Tracker spreadsheet.
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials/google-calendar-sa.json

# Scripting ignored attendees — these emails on filming events are
# filtered out before the agent tries to match the event to a student.
# Used by lib/gcal.js parseStudentFromEvent.
SCRIPTING_IGNORED_ATTENDEE_EMAILS=scott@limitlessyt.com,charles@limitlessyt.com,jack.oremus@alpha.school

# Content Performance Tracker (Google Sheet) — TWO-WAY sync used by the
# Profile Views Agent rebuild (docs/profile-views-rebuild-spec.md):
#   Direction 1 (sheet → videos): pull new post URLs Scott pastes in
#                                 column B of each per-student tab.
#   Direction 2 (performance → sheet): write the week's deltas back to
#                                 the matching `M/D-M/D` weekly column.
# Both directions live in tools/sheet-sync.js and run inside the agent's
# run() flow on every cron tick.
#
# Use a TEST copy of the sheet for staging. Promote to the production
# sheet ID only after manual spot-checks pass (rebuild spec §6).
GOOGLE_SHEET_ID_CONTENT_TRACKER=

# Legacy one-way sheet → performance sync (scripts/sync-performance-tracker.js).
# Decommissioned once the Profile Views Agent has written any
# apify-lineage rows for the campus (the script asserts no such rows
# exist before running). Kept here for backward reference; new work
# should use GOOGLE_SHEET_ID_CONTENT_TRACKER above.
PERFORMANCE_TRACKER_SHEET_ID=
PERFORMANCE_TRACKER_CAMPUS_ID=
PERFORMANCE_TRACKER_TABS=
PERFORMANCE_TRACKER_YEAR=
PERFORMANCE_TRACKER_DRY_RUN=

# Brand voice validator mode. One of: log_only, gate, off.
#   log_only (default) — validator runs, scores persist to video_quality_scores,
#                        failures never block the pipeline. Recommended until
#                        thresholds are calibrated (≥20 rows in video_quality_scores).
#   gate               — validator blocks concept writes on Layer 1 or Layer 2
#                        failure. 3 consecutive aborts for the same event_id
#                        escalate to processed_calendar_events.status=failed_cleanup.
#                        Flip intentionally, never default implicitly.
#   off                — skip all checks; overall_passed is always true. Use only
#                        during emergencies or when the validator itself is suspect.
BRAND_VOICE_VALIDATION_MODE=log_only

# Server
PORT=3000

# Health-ping agent (Phase A monitoring) — runs every minute via PM2 cron.
# Inserts ping rows into agent_logs that drive the dashboard's tunnel/pm2/
# ffmpeg/disk/memory pulse cells. See docs/dashboard-phase-a-spec.md.
#
# TUNNEL_URL: the public URL the world reaches the webhook server through
#   (Tailscale Funnel, ngrok, etc.). The ping fetches `${TUNNEL_URL}/health`
#   every minute. If unset, the tunnel ping records as error and the
#   dashboard's Webhook tunnel cell goes red.
TUNNEL_URL=
# CAMPUS_ID: which campus to attribute ping rows to. Defaults to Austin
#   (0ba4268f-f010-43c5-906c-41509bc9612f) if unset.
CAMPUS_ID=
